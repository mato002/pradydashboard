APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Set true only for local demos (auto-seeds sample servers, payments, etc.)
APP_DEMO_MODE=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Infrastructure telemetry (optional fleet-wide defaults)
INFRA_SYNC_ENABLED=true
INFRA_SYNC_INTERVAL=5
INFRA_WHM_PORT=2087
INFRA_WHM_USERNAME=root
INFRA_WHM_API_TOKEN=
INFRA_DIGITALOCEAN_TOKEN=
INFRA_HETZNER_TOKEN=

# License API (control plane)
PRADY_LICENSE_CACHE_TTL=600
PRADY_LICENSE_RATE_LIMIT=120
PRADY_LICENSE_REQUIRE_SIGNATURE=true
PRADY_LICENSE_LOG_CHECKS=true

# Payments Gateway control plane (payments.pradytecai.com)
PAYMENTS_GATEWAY_URL=https://payments.pradytecai.com
PAYMENTS_GATEWAY_ADMIN_TOKEN=
PAYMENTS_GATEWAY_TIMEOUT=30
PAYMENTS_GATEWAY_RETRY_ATTEMPTS=2
