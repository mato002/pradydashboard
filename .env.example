APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_TIMEZONE=Africa/Nairobi

# Set true only for local demos (auto-seeds sample servers, payments, etc.)
APP_DEMO_MODE=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# Use cache + redis when running multiple app instances (requires CACHE_STORE=redis):
# APP_MAINTENANCE_DRIVER=cache
# APP_MAINTENANCE_STORE=redis

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# phpredis is faster when the extension is installed; predis works without it.
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# Sessions + queues (default connection). Cache uses REDIS_CACHE_DB below.
REDIS_DB=0
REDIS_CACHE_DB=1
# Optional: isolate this app from other local Redis consumers (defaults to APP_NAME slug).
# REDIS_PREFIX=pradydashboard-database-
# CACHE_PREFIX=pradydashboard-cache-

# Operational summary cache (short TTL aggregates — not live financial truth)
REDIS_CACHE_ENABLED=true
# REDIS_CACHE_TTL_DASHBOARD=120
# REDIS_CACHE_TTL_BILLING=120
# REDIS_CACHE_TTL_FINANCIAL=180
# REDIS_CACHE_TTL_TENANT_CC=120
# REDIS_CACHE_TTL_SUPPORT=120
# REDIS_CACHE_TTL_FLEET=90
# REDIS_CACHE_TTL_RISK=120
# REDIS_CACHE_TTL_HR=600
# REDIS_CACHE_TTL_SETTINGS=3600

# Horizon (Linux/macOS production — requires pcntl; use queue:work on Windows locally)
# HORIZON_NAME=pradydashboard
# HORIZON_PATH=horizon
# HORIZON_PREFIX=pradydashboard_horizon:

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Infrastructure telemetry (optional fleet-wide defaults)
INFRA_SYNC_ENABLED=true
INFRA_SYNC_INTERVAL=5
INFRA_WHM_PORT=2087
INFRA_WHM_USERNAME=root
INFRA_WHM_API_TOKEN=
INFRA_DIGITALOCEAN_TOKEN=
INFRA_HETZNER_TOKEN=

# RBAC (set legacy open access only for local smoke tests)
# RBAC_LEGACY_OPEN_ACCESS=false
# RBAC_ELEVATION_TTL=15
# RBAC_BOOTSTRAP_GRANT_ELEVATION=true

# License API (control plane)
PRADY_LICENSE_CACHE_TTL=600
PRADY_LICENSE_RATE_LIMIT=120
PRADY_LICENSE_REQUIRE_SIGNATURE=true
PRADY_LICENSE_LOG_CHECKS=true

# Payments Gateway control plane (payments.pradytecai.com)
# Use the remote gateway or a separate local payments API port — never this dashboard app URL.
PAYMENTS_GATEWAY_URL=https://payments.pradytecai.com
PAYMENTS_GATEWAY_ADMIN_TOKEN=
PAYMENTS_GATEWAY_TIMEOUT=10
PAYMENTS_GATEWAY_RETRY_ATTEMPTS=1
